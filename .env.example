# Telegram contact delivery — SERVER-ONLY.
# Do NOT prefix with NEXT_PUBLIC_ (that would expose the token in the browser bundle).
# Copy this file to .env.local (gitignored) and fill in real values.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public canonical site URL (non-secret). Used for metadata and JSON-LD absolute URLs.
# Override when the final domain is decided (OQ1 — deploy day).
NEXT_PUBLIC_SITE_URL=https://hossammarey.com
